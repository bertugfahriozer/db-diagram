{
  "name": "db-diagram-designer",
  "displayName": "DB Diagram Designer",
  "description": "Visual database designer and ERD tool for MySQL and PostgreSQL. Create, edit and export diagrams.",
  "version": "1.0.0",
  "publisher": "bertugfahriozer",
  "author": {
    "name": "Bertuğ Fahri Özer"
  },
  "license": "MIT",
  "keywords": [
    "database",
    "diagram",
    "erd",
    "mysql",
    "postgresql",
    "sql"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "dbDiagram.connect",
        "title": "DB Diagram: Connect to Database",
        "icon": "$(database)"
      },
      {
        "command": "dbDiagram.openDiagram",
        "title": "DB Diagram: Open Diagram",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "dbDiagram.disconnect",
        "title": "DB Diagram: Disconnect"
      },
      {
        "command": "dbDiagram.deleteConnection",
        "title": "Delete Connection",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbDiagram",
          "title": "DB Diagram",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "dbDiagram": [
        {
          "id": "dbDiagramConnections",
          "name": "Saved Connections"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "dbDiagram.deleteConnection",
          "when": "view == dbDiagramConnections && viewItem == dbConnection",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js",
    "compile": "node esbuild.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "mysql2": "^3.6.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/vscode": "1.70.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
