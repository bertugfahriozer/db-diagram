# Dev tooling - VSIX'e dahil edilmez
.vscode/**
.github/**
.editorconfig
.gitignore
tsconfig.json
esbuild.js
PUBLISHING.md

# Kaynak dosyalar (derlendi, out/ yeterli)
src/**
out/*.map

